# ============================================================================
# SAFECITY Backend — variables de entorno
# Copia este archivo a .env y completa los valores reales.
# NUNCA versionar el archivo .env (ver .gitignore).
# ============================================================================

# Aplicación
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# Base de datos (PostgreSQL)
DATABASE_URL=postgresql://safecity:safecity_dev_password@localhost:5432/safecity?schema=public

# Redis (caché, rate limiting — se usa a partir de la Fase 2)
REDIS_URL=redis://localhost:6379

# JWT y Refresh Tokens (se completa en la Fase 2 — AuthModule)
JWT_SECRET=
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Almacenamiento de archivos (se completa cuando se implemente ReportsModule)
STORAGE_PROVIDER=local
STORAGE_BUCKET=

# Correo (se completa en la Fase 2 — recuperación de contraseña, verificación)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@safecity.local
